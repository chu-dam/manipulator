<mujoco model="rb5 gripper pick-and-insert scene">

    <include file="rb5_gripper.xml"/>

    <visual>
        <headlight diffuse="0.7 0.7 0.7" ambient="0.35 0.35 0.35" specular="0.15 0.15 0.15"/>
        <rgba haze="0.15 0.15 0.15 1"/>
        <global azimuth="135" elevation="-20"/>
        <quality shadowsize="16384"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient"
                 rgb1="0.85 0.90 0.95"
                 rgb2="0.20 0.25 0.35"
                 width="512" height="3072"/>

        <!-- STL is in mm, so scale to meters -->
        <mesh name="hole_13_mesh"
              file="/home/chu/manipulator_control/meshes/hole_13.stl"
              scale="0.001 0.001 0.001"/>

        <mesh name="peg_mesh"
              file="/home/chu/manipulator_control/meshes/peg.stl"
              scale="0.001 0.001 0.001"/>
    </asset>

    <worldbody>
        <!-- lights -->
        <light name="main_light"
               pos="0.0 -0.2 2.2"
               dir="0.0 -0.1 -1.0"
               directional="true"/>

        <light name="side_light"
               pos="0.8 0.4 1.6"
               dir="-0.4 -0.5 -1.0"
               directional="true"
               diffuse="0.5 0.5 0.5"
               specular="0.1 0.1 0.1"/>

        <!-- cameras -->
        <camera name="overview"
                pos="1.10 0.40 1.35"
                xyaxes="0 -1 0 0 0 1"/>

        <camera name="hole_closeup"
                pos="0.35 -0.30 0.85"
                xyaxes="0 -1 0 0 0 1"/>

        <camera name="pick_closeup"
                pos="0.45 -0.20 0.65"
                xyaxes="0 -1 0 0 0 1"/>

        <!-- =========================================================
             Hole fixture
             visual mesh + separate collision walls
             ========================================================= -->

        <!-- visual only -->
        <geom name="hole_13_visual"
              type="mesh"
              mesh="hole_13_mesh"
              pos="0.00 -0.68 0.0"
              quat="0.70710678 0.70710678 0 0"
              rgba="0.70 0.70 0.75 1"
              contype="0"
              conaffinity="0"/>

        <!-- collision only -->
        <body name="hole_collision" pos="0.00 -0.68 0.0" quat="0.70710678 0.70710678 0 0">
            <!--
              현재 값은 조금 넉넉한 시작점입니다.
              inner half size = 0.0068 -> opening 약 13.6 mm
              peg collision radius = 0.006 -> diameter 12 mm
            -->

            <!-- +X wall -->
            <geom name="hole_13_geom"
                  type="box"
                  pos="0.0084 0.0050 0.0"
                  size="0.0016 0.0050 0.0100"
                  rgba="0.2 0.8 0.2 0.15"
                  contype="2"
                  conaffinity="1"
                  margin="0.0005"
                  friction="1.0 0.005 0.0001"/>

            <!-- -X wall -->
            <geom name="hole_col_xn"
                  type="box"
                  pos="-0.0084 0.0050 0.0"
                  size="0.0016 0.0050 0.0100"
                  rgba="0.2 0.8 0.2 0.15"
                  contype="2"
                  conaffinity="1"
                  margin="0.0005"
                  friction="1.0 0.005 0.0001"/>

            <!-- +Z wall -->
            <geom name="hole_col_zp"
                  type="box"
                  pos="0.0 0.0050 0.0084"
                  size="0.0068 0.0050 0.0016"
                  rgba="0.2 0.8 0.2 0.15"
                  contype="2"
                  conaffinity="1"
                  margin="0.0005"
                  friction="1.0 0.005 0.0001"/>

            <!-- -Z wall -->
            <geom name="hole_col_zn"
                  type="box"
                  pos="0.0 0.0050 -0.0084"
                  size="0.0068 0.0050 0.0016"
                  rgba="0.2 0.8 0.2 0.15"
                  contype="2"
                  conaffinity="1"
                  margin="0.0005"
                  friction="1.0 0.005 0.0001"/>
        </body>

        <body name="hole_sites" pos="0.00 -0.68 0.0" quat="0.70710678 0.70710678 0 0">
            <site name="hole_bottom"    pos="0 0.000 0" size="0.0001" rgba="0 1 1 0"/>
            <site name="hole_center"    pos="0 0.005 0" size="0.0001" rgba="1 1 0 0"/>
            <site name="hole_entry"     pos="0 0.010 0" size="0.0001" rgba="0 1 0 0"/>
            <site name="hole_preinsert" pos="0 0.030 0" size="0.0001" rgba="1 0 1 0"/>
        </body>

        <!-- =========================================================
             Peg stand
             ========================================================= -->
        <body name="peg_stand" pos="0.20 -0.42 0.05">
            <geom name="peg_stand_geom"
                  type="box"
                  size="0.018 0.018 0.05"
                  rgba="0.35 0.35 0.38 1"
                  contype="2"
                  conaffinity="1"
                  margin="0.001"
                  friction="1.0 0.005 0.0001"/>
        </body>

        <!-- =========================================================
             Free peg
             visual mesh + simple collision cylinder
             ========================================================= -->
        <body name="peg" pos="0.20 -0.42 0.1005" quat="0.70710678 0.70710678 0 0">
            <freejoint/>

            <!-- 화면에 보이는 peg -->
            <geom name="peg_visual"
                type="mesh"
                mesh="peg_mesh"
                rgba="0.85 0.75 0.20 1"
                contype="0"
                conaffinity="0"/>

            <!-- 실제 충돌 계산용 peg -->
            <geom name="peg_geom"
                type="cylinder"
                fromto="0 0.000 0  0 0.020 0"
                size="0.006"
                mass="0.03"
                rgba="0 0 0 0"
                contype="1"
                conaffinity="3"
                margin="0.0005"
                friction="1.2 0.01 0.0001"/>

            <site name="peg_base"   pos="0 0.000 0" size="0.0001" rgba="1 0 0 0"/>
            <site name="peg_center" pos="0 0.010 0" size="0.0001" rgba="0 1 0 0"/>
            <site name="peg_tip"    pos="0 0.020 0" size="0.0001" rgba="0 0 1 0"/>
        </body>
    </worldbody>
</mujoco>