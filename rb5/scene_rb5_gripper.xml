<mujoco model="rb5 gripper peg-in-hole scene">

    <include file="rb5_gripper.xml"/>

    <visual>
        <headlight diffuse="0.7 0.7 0.7" ambient="0.35 0.35 0.35" specular="0.15 0.15 0.15"/>
        <rgba haze="0.15 0.15 0.15 1"/>
        <global azimuth="135" elevation="-20"/>
        <quality shadowsize="16384"/>
    </visual>

    <asset>
        <texture type="skybox" builtin="gradient"
                 rgb1="0.85 0.90 0.95"
                 rgb2="0.20 0.25 0.35"
                 width="512" height="3072"/>

        <!-- STL is in mm, so scale to meters -->
        <mesh name="hole_13_mesh"
              file="/home/chu/manipulator_control/meshes/hole_13.stl"
              scale="0.001 0.001 0.001"/>
    </asset>

    <worldbody>
        <!-- lights -->
        <light name="main_light"
               pos="0.0 -0.2 2.2"
               dir="0.0 -0.1 -1.0"
               directional="true"/>

        <light name="side_light"
               pos="0.8 0.4 1.6"
               dir="-0.4 -0.5 -1.0"
               directional="true"
               diffuse="0.5 0.5 0.5"
               specular="0.1 0.1 0.1"/>

        <!-- cameras -->
        <camera name="overview"
                pos="1.10 0.40 1.35"
                xyaxes="0 -1 0 0 0 1"/>

        <camera name="hole_closeup"
                pos="0.35 -0.30 0.85"
                xyaxes="0 -1 0 0 0 1"/>

        <!--
            hole_13 mesh dimensions:
            x: -10 ~ 10 mm
            y:   0 ~ 10 mm
            z: -10 ~ 10 mm

            So with pos="0 -0.68 0.10":
            - hole bottom(back face) is around y = -0.68
            - hole entry(front face) is around y = -0.67

            Robot approaches roughly along -Y direction.
        -->
        <body name="hole_fixture" pos="0.00 -0.68 0.0" quat="0.70710678 0.70710678 0 0">
            <geom name="hole_13_geom"
                  type="mesh"
                  mesh="hole_13_mesh"
                  rgba="0.70 0.70 0.75 1"
                  contype="2"
                  conaffinity="1"
                  friction="1.0 0.005 0.0001"/>

            <!-- reference sites -->
            <site name="hole_bottom"    pos="0 0.000 0" size="0.0035" rgba="0 1 1 0"/>
            <site name="hole_center"    pos="0 0.005 0" size="0.0035" rgba="1 1 0 0"/>
            <site name="hole_entry"     pos="0 0.010 0" size="0.0040" rgba="0 1 0 0"/>
            <site name="hole_preinsert" pos="0 0.030 0" size="0.0050" rgba="1 0 1 0"/>
        </body>
    </worldbody>
</mujoco>